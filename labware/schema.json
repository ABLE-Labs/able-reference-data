{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Labware",
  "type": "object",
  "required": ["key", "product_name", "category", "row_count", "column_count", "well_count", "spec"],
  "properties": {
    "key": {
      "type": "string",
      "description": "Unique identifier"
    },
    "product_name": { "type": "string" },
    "category": {
      "type": "string",
      "description": "e.g. Tip Box, Well Plate, Reservoir, Tube Rack"
    },
    "category_number": { "type": "string" },
    "company": { "type": "string" },
    "well_count": { "type": "integer", "minimum": 1 },
    "row_count": { "type": "integer", "minimum": 1 },
    "column_count": { "type": "integer", "minimum": 1 },
    "shape_well": { "type": "string", "description": "e.g. Circle, Square" },
    "shape_bottom": { "type": "string", "description": "e.g. U, V, F" },
    "spec": {
      "type": ["object", "null"],
      "required": ["well_count", "row_count", "column_count", "offset_x", "offset_y", "space_x", "space_y", "height", "depth"],
      "properties": {
        "well_count": { "type": "integer" },
        "row_count": { "type": "integer" },
        "column_count": { "type": "integer" },
        "offset_x": { "type": "number", "description": "First well X position (mm)" },
        "offset_y": { "type": "number", "description": "First well Y position (mm)" },
        "space_x": { "type": "number", "description": "Well spacing X (mm)" },
        "space_y": { "type": "number", "description": "Well spacing Y (mm)" },
        "height": { "type": "number", "description": "Labware total height (mm)" },
        "depth": { "type": "number", "description": "Well depth (mm)" },
        "volume_ul": { "type": "number", "description": "Max well volume (ul)" },
        "tip_info": {
          "type": "object",
          "properties": {
            "volume": { "type": "number" },
            "length": { "type": "number" },
            "overlap": { "type": "number" }
          }
        }
      }
    },
    "show": { "type": "boolean", "default": true },
    "verified_ablelabs": { "type": "boolean", "default": false },
    "verified_user": { "type": "boolean", "default": false },
    "custom_drawing": { "type": "boolean", "default": false },
    "drawing": { "type": "string", "description": "SVG filename (PocketBase file reference)" },
    "image": { "type": "string" },
    "web_link": { "type": "string" }
  },
  "additionalProperties": false
}
