{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LiquidClass",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "type": "string", "description": "Unique display name (used as identifier)" },
    "color": { "type": "string", "description": "Hex color e.g. #3B82F6, or empty string" },
    "verified": { "type": "boolean", "default": false },
    "parameter": { "type": "object" }
  },
  "additionalProperties": false
}
